# Windows NTFS metadata (WSL artifact)
*:Zone.Identifier

# Wallpapers / lock screen images (binary assets, not worth tracking)
.config/assets/

# Neovim plugins (managed by vim-plug, not tracked in dotfiles)
.config/nvim/plugged/

# Go runtime data
.config/go/

# Pulse audio runtime data
.config/pulse/

# Backup / temp files
*.bak
*.orig
*.swp
*~
